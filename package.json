    "@storybook/addon-themes": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "chromatic": "^17.5.0",
    "gh-pages": "^6.3.0",
    "storybook": "^8.4.7",
    "style-dictionary": "^4.2.0",
